set -e

COMMAND=$1

case "$COMMAND" in
  test)
    echo "========================================="
    echo "🚀 Running twin-cities-concierage-agent evaluations..."
    echo "========================================="
    agents-cli eval run
    ;;
  deploy)
    echo "========================================="
    echo "🚀 Deploying twin-cities-concierage-agent to Agent Engine (Production)..."
    echo "========================================="
    uv run --with google-agents-cli==0.1.3 python -c "
from google.agents.cli._project import read_project_config
from google.agents.cli.deploy.agent_runtime import deploy_agent_runtime
cfg = read_project_config()
deploy_agent_runtime(
    cfg=cfg,
    project='lpr-gemini-enterprise-1',
    location='us-central1',
    display_name='Twin Cities Concierage Agent',
)
"
    ;;
  *)
    echo "Usage: ./agent {test|deploy}"
    exit 1
    ;;
esac
